PORT=3000
DB_USER=postgres
DB_HOST=localhost
DB_NAME=itpapp
DB_PASSWORD=password
DB_PORT=5432
JWT_SECRET=your_jwt_secret_here

# Email Configuration (e.g., Mailtrap for testing or AWS SES for production)
