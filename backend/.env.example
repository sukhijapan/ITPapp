# Application URL (used for links in emails)
APP_URL=http://localhost:5173

# Legacy email config (still supported as fallback)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_user
EMAIL_PASS=your_pass
